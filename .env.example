# ============================================
# GitHub OAuth — 用于 Sveltia CMS 登录（可选）
# ============================================
# Sveltia CMS 默认支持 Token 登录，无需额外配置
# 如需使用 OAuth 授权码流程，可沿用已有的 GitHub OAuth App：
# 1. 访问 https://github.com/settings/developers
# 2. 找到或新建 OAuth App "墨墨梧文 CMS"
# 3. Homepage URL: https://www.10012049.xyz
# 4. Authorization callback URL: https://www.10012049.xyz/api/oauth
# ============================================
GITHUB_CLIENT_ID=your-github-client-id-here
GITHUB_CLIENT_SECRET=your-github-client-secret-here

# 站点 URL（用于安全头等场景）
# NEXT_PUBLIC_SITE_URL=https://www.10012049.xyz

# ============================================
# Admin 面板保护 — Basic Auth 用户名和密码
# 生产环境必须设置，开发环境可注释
# ============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here