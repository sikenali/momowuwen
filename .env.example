# GitHub OAuth — 用于 Decap CMS 登录
# 在 https://github.com/settings/developers 创建 OAuth App
# 回调 URL 设置为 https://你的域名/api/oauth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth 回调地址（可选，默认自动使用当前域名）
# OAUTH_REDIRECT_URI=https://www.10012049.xyz/api/oauth

# 站点 URL（用于安全头等场景）
# NEXT_PUBLIC_SITE_URL=https://www.10012049.xyz

# Admin 面板保护 — Basic Auth 用户名和密码
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-secure-password