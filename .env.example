# ============================================
# GitHub OAuth — 用于 Decap CMS 登录
# ============================================
# 1. 访问 https://github.com/settings/developers
# 2. 点击 "New OAuth App"
# 3. Application name: 墨墨梧文 CMS
# 4. Homepage URL: https://www.10012049.xyz
# 5. Authorization callback URL: https://www.10012049.xyz/api/oauth
# 6. 复制 Client ID 和 Client Secret 到下方
# ============================================
GITHUB_CLIENT_ID=your-github-client-id-here
GITHUB_CLIENT_SECRET=your-github-client-secret-here

# OAuth 回调地址（可选，默认自动使用当前域名）
# OAUTH_REDIRECT_URI=https://www.10012049.xyz/api/oauth

# 站点 URL（用于安全头等场景）
# NEXT_PUBLIC_SITE_URL=https://www.10012049.xyz

# ============================================
# Admin 面板保护 — Basic Auth 用户名和密码
# 生产环境必须设置，开发环境可注释
# ============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here